# Normalize line endings: LF in repo, native on checkout
* text=auto

# Force LF for shell scripts (must stay LF even on Windows)
*.sh text eol=lf

# Notebooks — treat as binary to avoid merge-conflict noise on output cells
*.ipynb binary

# Binary files — no line ending conversion
*.safetensors binary
*.bin binary
*.pt binary
*.png binary
*.pdf binary
*.jpg binary
*.jpeg binary
