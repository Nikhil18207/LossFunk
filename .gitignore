# =============================================================================
# LoRA Backdoor Research — .gitignore
# =============================================================================
# RULE: Code + small text data → Git
#       Large model weights / tensors  → DVC  (tracked, not stored in Git)
#       Caches / envs / generated plots → ignored entirely
# =============================================================================


# -----------------------------------------------------------------------------
# Python virtual environment (Lora/ folder IS the venv)
# -----------------------------------------------------------------------------
Lora/
venv/
.venv/
env/
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# Python bytecode & caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints/
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# Model weights — TRACKED BY DVC, not stored in Git
# Large safetensors, PyTorch checkpoints, Fisher diagonal tensors
# -----------------------------------------------------------------------------
*.safetensors
*.bin
*.pt
*.ckpt
*.pth

# Entire models directories (weights live here)
notebooks/models/
models/

# -----------------------------------------------------------------------------
# HuggingFace Hub download caches — re-downloadable, do NOT commit
# -----------------------------------------------------------------------------
hub_cache/
hub_cache_scaled/
.cache/
~/.cache/huggingface/

# -----------------------------------------------------------------------------
# Generated figures — regenerated by running the scripts/notebooks
# -----------------------------------------------------------------------------
**/figures/

# -----------------------------------------------------------------------------
# Generated lock files & compiled outputs
# -----------------------------------------------------------------------------
requirements.lock.txt
*.lock

# -----------------------------------------------------------------------------
# OS & editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# DVC internals — .dvc files ARE committed (they're pointers), but not the cache
# -----------------------------------------------------------------------------
.dvc/cache/
.dvc/tmp/
/tmp/

# -----------------------------------------------------------------------------
# Misc experiment artifacts that can be regenerated
# -----------------------------------------------------------------------------
*.log
wandb/
runs/
lightning_logs/
